# Port for the backend API
PORT=3000
NODE_ENV=development

# Database connection string
# For local dev, a safe default is used if this is missing.
DATABASE_URL="mysql://root:password@localhost:3306/chatup_dev"

# JWT Secrets
JWT_ACCESS_SECRET="your_secret_access_key_here"
JWT_REFRESH_SECRET="your_secret_refresh_key_here"

# Token expiration times
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# S3 Configuration (Yandex Object Storage)
S3_ENDPOINT="https://s3.yandexcloud.net"
S3_ACCESS_KEY_ID="your_access_key"
S3_SECRET_ACCESS_KEY="your_secret_key"
S3_BUCKET="chatup-bucket"
S3_REGION="ru-central1"

# Web Push (VAPID) for PWA push notifications
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_SUBJECT="mailto:you@example.com"

# Firebase service account for native mobile push (FCM)
# Prefer BASE64 in production to avoid multiline escaping issues.
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_SERVICE_ACCOUNT_BASE64=""
